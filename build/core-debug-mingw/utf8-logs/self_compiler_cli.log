==== Toy Backend 命令流 ====
ALLOC input_ids 0 64
ALLOC hidden_states 64 65536
ALLOC block_output 65600 65536
ALLOC logits 131136 4104192
EXEC input Input
EXEC embedding Embedding
EXEC transformer_block_0.rmsnorm0 RmsNorm
EXEC transformer_block_0.qkv QkvProject
EXEC transformer_block_0.rope Rope
EXEC transformer_block_0.attention Attention
EXEC transformer_block_0.residual0 ResidualAdd
EXEC transformer_block_0.rmsnorm1 RmsNorm
EXEC transformer_block_0.swiglu SwiGLU
EXEC transformer_block_0.residual1 ResidualAdd
EXEC lm_head LmHead
EXEC output Output

